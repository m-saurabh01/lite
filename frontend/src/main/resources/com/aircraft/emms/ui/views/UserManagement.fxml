<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.aircraft.emms.ui.controller.UserManagementController"
      stylesheets="@../css/styles.css">

    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="User Management" styleClass="section-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="userSearchField" promptText="Search users..." styleClass="search-field" prefWidth="200"/>
        <Button text="Refresh" onAction="#handleRefresh" styleClass="btn-secondary"/>
    </HBox>

    <TableView fx:id="userTable" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn text="ID" prefWidth="50">
                <cellValueFactory><PropertyValueFactory property="id"/></cellValueFactory>
            </TableColumn>
            <TableColumn text="Service ID" prefWidth="120">
                <cellValueFactory><PropertyValueFactory property="serviceId"/></cellValueFactory>
            </TableColumn>
            <TableColumn text="Name" prefWidth="150">
                <cellValueFactory><PropertyValueFactory property="name"/></cellValueFactory>
            </TableColumn>
            <TableColumn text="Roles" prefWidth="250">
                <cellValueFactory><PropertyValueFactory property="rolesDisplay"/></cellValueFactory>
            </TableColumn>
            <TableColumn text="Active" prefWidth="80">
                <cellValueFactory><PropertyValueFactory property="active"/></cellValueFactory>
            </TableColumn>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button fx:id="editUserBtn" text="Edit" onAction="#handleEditUser" styleClass="btn-secondary" disable="true"/>
        <Button fx:id="deactivateBtn" text="Deactivate" onAction="#handleDeactivateUser" styleClass="btn-danger" disable="true"/>
    </HBox>

    <Label fx:id="successLabel" styleClass="success-label" wrapText="true"/>
    <Label fx:id="userErrorLabel" styleClass="error-label" wrapText="true"/>

    <!-- User Form -->
    <TitledPane fx:id="userFormPane" text="User Details" expanded="false" animated="true">
        <GridPane hgap="10" vgap="10">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <columnConstraints>
                <ColumnConstraints minWidth="120" prefWidth="120"/>
                <ColumnConstraints minWidth="300" prefWidth="350"/>
            </columnConstraints>
            <Label text="Service ID:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="serviceIdField" GridPane.columnIndex="1" GridPane.rowIndex="0" maxWidth="Infinity" editable="false"/>
            <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="Infinity"/>
            <Label text="Roles:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <MenuButton fx:id="rolesMenuButton" text="Select Roles..." GridPane.columnIndex="1" GridPane.rowIndex="2" maxWidth="Infinity"/>
            <Label text="Password:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <PasswordField fx:id="passwordField" GridPane.columnIndex="1" GridPane.rowIndex="3" maxWidth="Infinity"/>
            <Label text="Security Question:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
            <TextField fx:id="securityQuestionField" GridPane.columnIndex="1" GridPane.rowIndex="4" maxWidth="Infinity"/>
            <Label text="Security Answer:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
            <PasswordField fx:id="securityAnswerField" GridPane.columnIndex="1" GridPane.rowIndex="5" maxWidth="Infinity"/>
            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="6">
                <Button text="Save" onAction="#handleSaveUser" styleClass="btn-primary"/>
                <Button text="Cancel" onAction="#handleCancelForm" styleClass="btn-secondary"/>
            </HBox>
        </GridPane>
    </TitledPane>
</VBox>
